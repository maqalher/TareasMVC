@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<h1>Login</h1>

@if (ViewData.Keys.Contains("mensaje"))
{
    <p style="color: red;">
        @ViewData["mensaje"]
    </p>
}

<div class="card">
    <div class="card-body">
        <form asp-action="Login">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" autocomplete="off" class="form-control" />
                <span class="text-danger" asp-validation-for="Email"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span class="text-danger" asp-validation-for="Password"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="Recuerdame" type="checkbox" class="form-check-input" />
                <label asp-for="Recuerdame" class="form-check-label"></label>
            </div>

            <button class="btn-primary btn">Login</button>
            <a asp-action="registro" class="btn btn-success">Crear cuenta</a>

            <a asp-action="LoginExterno" class="btn btn-success" asp-route-proveedor="Microsoft">Continuar con Microsoft</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
